APP_NAME=pragent-service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=9090
API_PREFIX=/api/pragent
APP_DEMO_MODE=false

DATABASE_URL=mysql+aiomysql://root:root@mysql:3306/pragent?charset=utf8mb4
REDIS_URL=redis://:123456@redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/data/storage
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=pragent
S3_USE_SSL=false

MCP_SERVER_URL=http://mcp-server:9099

OPENAI_API_KEY=     #兼容皆可
OPENAI_BASE_URL= 
OPENAI_CHAT_MODEL= 
OPENAI_EMBEDDING_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_CHAT_MODEL=
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest

RAG_DEFAULT_COLLECTION=rag_default_store
RAG_EMBEDDING_DIMENSION=1024
RAG_METRIC_TYPE=Cosine
RAG_HISTORY_KEEP_TURNS=4
RAG_SUMMARY_START_TURNS=5
RAG_SUMMARY_ENABLED=true
RAG_SUMMARY_MAX_CHARS=200
RAG_TITLE_MAX_LENGTH=30
RAG_QUERY_REWRITE_ENABLED=true
RAG_QUERY_REWRITE_MAX_HISTORY_MESSAGES=4
RAG_QUERY_REWRITE_MAX_HISTORY_CHARS=500
RAG_GLOBAL_RATE_LIMIT_ENABLED=true
RAG_GLOBAL_MAX_CONCURRENT=1
RAG_GLOBAL_MAX_WAIT_SECONDS=3
RAG_GLOBAL_LEASE_SECONDS=30
RAG_GLOBAL_POLL_INTERVAL_MS=200
RAG_VECTOR_GLOBAL_CONFIDENCE_THRESHOLD=0.6
RAG_VECTOR_GLOBAL_TOP_K_MULTIPLIER=3
RAG_INTENT_DIRECTED_MIN_INTENT_SCORE=0.4
RAG_INTENT_DIRECTED_TOP_K_MULTIPLIER=2

MODEL_FAILURE_THRESHOLD=2
MODEL_OPEN_DURATION_MS=30000
STREAM_MESSAGE_CHUNK_SIZE=8
